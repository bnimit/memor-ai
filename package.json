{
  "name": "memor-ai",
  "version": "0.1.0",
  "description": "Measured memory layer for coding agents — store, distill, and retrieve past session context instead of re-sending full history",
  "keywords": ["ai", "memory", "agent", "coding", "retrieval", "claude", "llm", "memor"],
  "license": "MIT",
  "bin": {
    "memor": "./bin/memor.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "memor/",
    "skill/",
    "inspector.py",
    "pyproject.toml"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "node bin/memor.mjs",
    "inspector": "node bin/memor.mjs inspector"
  },
  "engines": {
    "node": ">=18"
  }
}
